{
  "name": "servicebook-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start":            "node src/server.js",
    "dev":              "nodemon src/server.js",
    "migrate":          "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:status":   "knex migrate:status",
    "slots:generate":   "node src/jobs/slotGenerator.js",
    "cleanup":          "node src/jobs/cleanupJob.js",
    "test":             "NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "test:unit":        "NODE_OPTIONS=--experimental-vm-modules jest tests/unit --runInBand",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest tests/integration --runInBand"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "mysql2": "^3.20.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "jest": "^30.3.0",
    "knex": "^3.2.4",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}